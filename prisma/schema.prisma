generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProductStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  ARCHIVED
}

enum ProductCondition {
  NEW
  OPEN_BOX
  USED_EXCELLENT
  USED_GOOD
  USED_FAIR
  FOR_PARTS
}

enum CameraType {
  VINTAGE_DIGITAL
  FILM_CAMERA
  ACCESSORY
  PARTS_REPAIR
}

enum CameraFormat {
  DIGITAL
  FILM
  ACCESSORY
}

enum ProductImageRole {
  HERO
  GALLERY
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  MANUAL
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELED
}

enum FulfillmentStatus {
  UNFULFILLED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model Product {
  id                String           @id @default(cuid())
  sku               String?          @unique
  slug              String           @unique
  title             String
  brand             String
  manufacturer      String           @default("")
  model             String
  categorySlug      String
  categorySlugs     String[]         @default([])
  subcategorySlug   String           @default("")
  productType       String           @default("")
  cameraType        CameraType       @default(VINTAGE_DIGITAL)
  format            CameraFormat     @default(DIGITAL)
  condition         ProductCondition @default(USED_GOOD)
  functionalStatus  String           @default("Tested")
  testedStatus      String           @default("Tested")
  conditionSummary  String           @default("")
  conditionNotes    String           @default("")
  priceCents        Int
  quantity          Int              @default(1)
  status            ProductStatus    @default(DRAFT)
  description       String           @default("")
  shortDescription  String           @default("")
  seoTitle          String?
  seoDescription    String           @default("")
  tags              String[]         @default([])
  lensMount         String           @default("")
  filmFormat        String           @default("")
  storageType       String           @default("")
  includesBattery   Boolean          @default(false)
  includesCharger   Boolean          @default(false)
  includesMemoryCard Boolean         @default(false)
  includesCase      Boolean          @default(false)
  includesStrap     Boolean          @default(false)
  includesManual    Boolean          @default(false)
  includesOriginalBox Boolean        @default(false)
  actualPhotos      Boolean          @default(false)
  samplePhotos      Boolean          @default(false)
  partsRepair       Boolean          @default(false)
  forPartsOrRepair  Boolean          @default(false)
  featured          Boolean          @default(false)
  newArrival        Boolean          @default(false)
  badges            String[]         @default([])
  included          String[]         @default([])
  doesNotInclude    String[]         @default([])
  tested            String[]         @default([])
  goodFor           String[]         @default([])
  cosmeticNotes     String[]         @default([])
  functionalNotes   String[]         @default([])
  flaws             String[]         @default([])
  notes             String[]         @default([])
  shippingNote      String           @default("")
  returnsNote       String           @default("")
  checkoutUrl       String?
  mainImageUrl      String           @default("")
  imageUrls         String[]         @default([])
  images            ProductImage[]
  customerLikes     CustomerProductLike[]
  orderItems        OrderItem[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([slug])
  @@index([status])
  @@index([brand])
  @@index([categorySlug])
  @@index([subcategorySlug])
  @@index([productType])
  @@index([functionalStatus])
  @@index([featured])
  @@index([newArrival])
}

model ProductImage {
  id        String           @id @default(cuid())
  productId String
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String           @default("")
  role      ProductImageRole @default(GALLERY)
  sortOrder Int              @default(0)
  publicId  String?
  createdAt DateTime         @default(now())

  @@index([productId, role, sortOrder])
}

model Customer {
  id                      String                           @id @default(cuid())
  email                   String                           @unique
  passwordHash            String
  name                    String?
  emailVerifiedAt         DateTime?
  emailVerificationTokens CustomerEmailVerificationToken[]
  productLikes            CustomerProductLike[]
  orders                  Order[]
  createdAt               DateTime                         @default(now())
  updatedAt               DateTime                         @updatedAt

  @@index([email])
}

model CustomerEmailVerificationToken {
  id        String    @id @default(cuid())
  customerId String
  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([customerId])
  @@index([expiresAt])
}

model CustomerProductLike {
  id         String   @id @default(cuid())
  customerId String
  productId  String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
  @@index([customerId, createdAt])
  @@index([productId])
}

model Order {
  id                String             @id @default(cuid())
  orderNumber       String             @unique
  customerId        String?
  customer          Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerEmail     String
  customerName      String?
  customerPhone     String?
  shippingAddress   Json?
  billingAddress    Json?
  provider          PaymentProvider    @default(STRIPE)
  providerReference String?            @unique
  stripeCheckoutSessionId String?      @unique
  stripePaymentIntentId String?        @unique
  customerEmailSendingAt DateTime?
  customerEmailSentAt DateTime?
  adminEmailSendingAt DateTime?
  adminEmailSentAt DateTime?
  status            OrderStatus        @default(PENDING_PAYMENT)
  paymentStatus     PaymentStatus      @default(PENDING)
  fulfillmentStatus FulfillmentStatus  @default(UNFULFILLED)
  currency          String             @default("USD")
  subtotalCents     Int
  shippingCents     Int                @default(0)
  taxCents          Int                @default(0)
  totalCents        Int
  trackingNumber    String?
  notes             String?
  items             OrderItem[]
  history           OrderStatusEvent[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([paymentStatus])
  @@index([fulfillmentStatus])
  @@index([status])
  @@index([customerId])
  @@index([customerEmail])
  @@index([createdAt])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String?
  product        Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productSlug    String
  productSku     String   @default("")
  productTitle   String
  conditionLabel String
  imageUrl       String?
  quantity       Int
  unitPriceCents Int
  totalPriceCents Int
  createdAt      DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

model OrderStatusEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  message   String
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}
